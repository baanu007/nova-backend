# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://YOUR_RAILWAY_URL/auth/google/callback

# Backend config
BACKEND_URL=https://YOUR_RAILWAY_URL
NOVA_APP_URL=https://nova.pplx.app
ALLOWED_ORIGINS=https://nova.pplx.app,http://localhost:3000

# Security — generate a strong random string
ENCRYPTION_KEY=change-this-to-a-long-random-secret-string

# Railway sets PORT automatically, don't override
